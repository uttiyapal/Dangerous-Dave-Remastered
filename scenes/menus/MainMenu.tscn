theme_override_fonts/font = ExtResource("2_bqojv")
theme_override_font_sizes/font_size = 20
text = "
Move: W / A / S /  D

Jump: Space

Shoot: Left Mouse Button

Jetpack: Left Ctrl (Hold)

Objective:
• Collect gems, coins for points, and hearts for health.
• For every 3 damage to health, player loses a life.
• Pick up the key to unlock the exit door.
• Fire the gun to defeat monsters.
• Use the jetpack to reach difficult areas.
• Avoid monsters, fire and lava.
• Reach the exit door to complete each level.
"
autowrap_mode = 2

